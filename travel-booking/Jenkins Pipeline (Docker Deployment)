pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Frontend') {
            steps {
                sh '''
                cd travel-booking
                docker build -t travel-frontend .
                '''
            }
        }

        stage('Build Backend') {
            steps {
                sh '''
                cd travel-booking
                docker build -t travel-backend ./backend
                '''
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                docker rm -f travel-frontend || true
                docker rm -f travel-backend || true

                docker run -d \
                --name travel-frontend \
                -p 80:80 \
                travel-frontend

                docker run -d \
                --name travel-backend \
                -p 5000:5000 \
                travel-backend
                '''
            }
        }
    }
}
